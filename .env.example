# Gmail SMTP 发送账号（必填）
# 1. 必须开启 Google 账号两步验证
# 2. 在 https://myaccount.google.com/apppasswords 生成「应用专用密码」
# 3. 把 16 位密码（含或不含空格均可）填到 GMAIL_APP_PASSWORD
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 收件人（必填，至少一个；多个用逗号或分号分隔）
REPORT_RECIPIENTS=you@example.com

# 兼容旧字段：单收件人。REPORT_RECIPIENTS 缺失时回退到这里
RECIPIENT_EMAIL=you@example.com
