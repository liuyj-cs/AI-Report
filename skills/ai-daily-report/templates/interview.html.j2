<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<title>AI 访谈 · {{ report.person }}</title>
<style>
  :root { --bg:#ffffff; --fg:#1f2328; --muted:#656d76; --accent:#0969da; --accent-soft:#f0f7ff; --card:#ffffff; --border:#d0d7de; }
  @media (prefers-color-scheme: dark) { :root { --bg:#0d1117; --fg:#e6edf3; --muted:#8d96a0; --accent:#58a6ff; --accent-soft:#121d2f; --card:#161b22; --border:#30363d; } }
  body { margin:0; background:var(--bg); color:var(--fg); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif; line-height:1.7; }
  .container { max-width:720px; margin:0 auto; padding:20px 16px 48px; }
  header { border-bottom:2px solid var(--accent); padding-bottom:12px; margin-bottom:20px; }
  h1 { font-size:22px; margin:0 0 6px; }
  .meta { color:var(--muted); font-size:14px; }
  .meta a { color:var(--accent); word-break:break-all; }
  .badge { display:inline-block; padding:2px 10px; border-radius:12px; font-size:12px; font-weight:500; margin-right:6px; background:var(--accent-soft); color:var(--accent); }
  h2 { font-size:17px; margin:24px 0 8px; border-left:4px solid var(--accent); padding-left:10px; }
  section p { margin:8px 0; font-size:15px; }
  ul { margin:8px 0; padding-left:22px; font-size:15px; }
  blockquote { border-left:3px solid var(--border); margin:10px 0; padding:4px 12px; color:var(--muted); font-style:italic; }
  .role { font-weight:600; }
  .refs a { color:var(--accent); word-break:break-all; }
  footer { margin-top:32px; color:var(--muted); font-size:13px; border-top:1px solid var(--border); padding-top:12px; }
</style>
</head>
<body>
{% set mode_labels = {"linked_zh_transcript": "已有中文整理稿", "self_translated_full": "自产全文中译", "deep_summary_fallback": "结构化深度摘要"} %}
<div class="container">
  <header>
    <h1>AI 访谈 · {{ report.person }}</h1>
    <div class="meta">
      {{ report.org }} · {{ report.role }} · <span class="badge">{{ mode_labels[report.mode] }}</span><br>
      {{ report.outlet }} · 发布 {{ report.published_at }} · <a href="{{ report.original_url }}">原文</a>
      {% if report.chinese_transcript.available and report.chinese_transcript.url %} · <a href="{{ report.chinese_transcript.url }}">中文整理稿{% if report.chinese_transcript.outlet %}（{{ report.chinese_transcript.outlet }}）{% endif %}</a>{% endif %}
    </div>
  </header>

  <section><h2>导读</h2><p>{{ report.lede }}</p></section>

  <section>
    <h2>核心观点</h2>
    <ul>{% for p in report.key_points %}<li>{{ p }}</li>{% endfor %}</ul>
  </section>

  {% if report.notable_quotes %}
  <section>
    <h2>金句</h2>
    {% for q in report.notable_quotes %}<blockquote>"{{ q.quote_zh }}"{% if q.src %} <span class="meta">— {{ q.src }}</span>{% endif %}</blockquote>{% endfor %}
  </section>
  {% endif %}

  <section>
    <h2>对四个角色意味着什么</h2>
    <ul>{% for entry in report.role_implications %}<li><span class="role">{{ entry.role }}：</span>{{ entry.implication }}</li>{% endfor %}</ul>
  </section>

  {% if report.full_translation %}
  <section>
    <h2>全文中译</h2>
    {% for seg in report.full_translation %}{% if seg.heading %}<h3>{{ seg.heading }}</h3>{% endif %}<p>{{ seg.body }}</p>{% endfor %}
  </section>
  {% endif %}

  {% if report.follow_ups %}
  <section>
    <h2>值得继续跟进</h2>
    <ul>{% for f in report.follow_ups %}<li>{{ f }}</li>{% endfor %}</ul>
  </section>
  {% endif %}

  <section class="refs">
    <h2>引用</h2>
    <ul>{% for ref in report.references %}<li>{{ ref.source }} — <a href="{{ ref.url }}">{{ ref.url }}</a></li>{% endfor %}</ul>
  </section>

  <footer>生成于 {{ report.date }} · AI 日报负责人访谈</footer>
</div>
</body>
</html>
