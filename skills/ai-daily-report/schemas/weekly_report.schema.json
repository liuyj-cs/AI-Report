{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIWeeklyReport",
  "type": "object",
  "required": ["version", "type", "week_end", "window", "generated_at", "sections", "source_days"],
  "properties": {
    "version": {"const": "1.0"},
    "type": {"const": "weekly"},
    "week_end": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "window": {
      "type": "object",
      "required": ["start", "end", "timezone"],
      "properties": {
        "start": {"type": "string"},
        "end": {"type": "string"},
        "timezone": {"type": "string"}
      }
    },
    "generated_at": {"type": "string"},
    "sections": {
      "type": "object",
      "required": [
        "tldr",
        "frontier_models",
        "coding_agents",
        "general_agents",
        "market_signals",
        "pattern_observations",
        "experiments_this_week",
        "practice_digest",
        "action_items",
        "next_week_signals"
      ],
      "properties": {
        "tldr": {
          "type": "object",
          "required": ["title", "bullets"],
          "properties": {
            "title": {"type": "string"},
            "bullets": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 3,
              "maxItems": 5
            }
          }
        },
        "frontier_models": {
          "type": "object",
          "required": ["title", "vendor_groups"],
          "properties": {
            "title": {"type": "string"},
            "vendor_groups": {
              "type": "array",
              "items": {"$ref": "#/$defs/vendorGroup"}
            }
          }
        },
        "coding_agents": {
          "type": "object",
          "required": ["title", "product_groups", "top_changes"],
          "properties": {
            "title": {"type": "string"},
            "product_groups": {
              "type": "array",
              "items": {"$ref": "#/$defs/productGroup"}
            },
            "top_changes": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "general_agents": {
          "type": "object",
          "required": ["title", "newcomers", "big_lab_moves", "trend_judgment", "implication"],
          "properties": {
            "title": {"type": "string"},
            "newcomers": {"type": "array"},
            "big_lab_moves": {"type": "array"},
            "trend_judgment": {"type": "string"},
            "implication": {"type": "string"}
          }
        },
        "market_signals": {"$ref": "#/$defs/marketSignalsSection"},
        "pattern_observations": {
          "type": "object",
          "required": ["title", "items", "empty_message"],
          "properties": {
            "title": {"type": "string"},
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 3,
              "items": {"$ref": "#/$defs/patternObservation"}
            },
            "empty_message": {"type": "string"}
          }
        },
        "experiments_this_week": {
          "type": "object",
          "required": ["title", "items", "empty_message"],
          "properties": {
            "title": {"type": "string"},
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 3,
              "items": {"$ref": "#/$defs/experiment"}
            },
            "empty_message": {"type": "string"}
          }
        },
        "practice_digest": {
          "type": "object",
          "required": ["title", "items", "empty_message"],
          "properties": {
            "title": {"type": "string"},
            "items": {
              "type": "array",
              "maxItems": 2,
              "items": {"$ref": "#/$defs/practiceDigestItem"}
            },
            "empty_message": {"type": "string"}
          }
        },
        "action_items": {
          "type": "object",
          "required": ["title", "items"],
          "properties": {
            "title": {"type": "string"},
            "items": {
              "type": "array",
              "items": {"$ref": "#/$defs/actionItem"}
            }
          }
        },
        "next_week_signals": {
          "type": "object",
          "required": ["title", "announced", "threads"],
          "properties": {
            "title": {"type": "string"},
            "announced": {"type": "array"},
            "threads": {"type": "array"}
          }
        }
      }
    },
    "source_days": {
      "type": "object",
      "required": ["daily_reports_used", "backfilled"],
      "properties": {
        "daily_reports_used": {
          "type": "array",
          "items": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
        },
        "backfilled": {
          "type": "array",
          "items": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
        }
      }
    }
  },
  "$defs": {
    "vendorGroup": {
      "type": "object",
      "required": ["vendor", "vendor_region", "weekly_changes", "trend_judgment", "implication", "references"],
      "properties": {
        "vendor": {"type": "string"},
        "vendor_region": {"enum": ["US", "CN"]},
        "weekly_changes": {"type": "string"},
        "trend_judgment": {"type": "string"},
        "implication": {"type": "string"},
        "references": {
          "type": "array",
          "items": {"$ref": "#/$defs/reference"}
        }
      }
    },
    "productGroup": {
      "type": "object",
      "required": ["product", "weekly_changes", "trend_judgment", "implication", "references"],
      "properties": {
        "product": {"type": "string"},
        "weekly_changes": {"type": "string"},
        "trend_judgment": {"type": "string"},
        "implication": {"type": "string"},
        "references": {
          "type": "array",
          "items": {"$ref": "#/$defs/reference"}
        }
      }
    },
    "itemRef": {
      "type": "string",
      "pattern": "^(frontier_models|coding_agents|general_agents)\\[(0|[1-9][0-9]*)\\]$"
    },
    "benchmarkChange": {
      "type": "object",
      "required": ["vendor", "model", "source", "metric", "old_value", "new_value", "change_pct", "observed_at"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "source": {"type": "string"},
        "metric": {"type": "string"},
        "old_value": {"type": "number"},
        "new_value": {"type": "number"},
        "change_pct": {"type": "number"},
        "observed_at": {"type": "string"},
        "note": {"type": "string", "maxLength": 80}
      }
    },
    "benchmarkWatch": {
      "type": "object",
      "required": ["vendor", "model", "source", "signal", "observed_at"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "source": {"type": "string"},
        "signal": {"type": "string", "maxLength": 180},
        "observed_at": {"type": "string"},
        "note": {"type": "string", "maxLength": 100},
        "ref": {"$ref": "#/$defs/itemRef"}
      }
    },
    "pricingChange": {
      "type": "object",
      "required": ["vendor", "model", "old_price_per_mtok", "new_price_per_mtok", "change_pct", "direction", "observed_at"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "price_type": {"enum": ["input", "output", "blended"]},
        "currency": {"type": "string"},
        "old_price_per_mtok": {"type": "number", "minimum": 0},
        "new_price_per_mtok": {"type": "number", "minimum": 0},
        "change_pct": {"type": "number"},
        "direction": {"enum": ["up", "down", "flat"]},
        "observed_at": {"type": "string"},
        "note": {"type": "string", "maxLength": 80}
      }
    },
    "adoptionSignal": {
      "type": "object",
      "required": ["vendor", "product", "metric", "value", "source", "observed_at"],
      "properties": {
        "vendor": {"type": "string"},
        "product": {"type": "string"},
        "metric": {"enum": ["paid_seats", "arr", "weekly_engagement", "customer_count", "usage_share", "other"]},
        "value": {"type": "string", "maxLength": 80},
        "source": {"type": "string"},
        "observed_at": {"type": "string"},
        "note": {"type": "string", "maxLength": 120},
        "ref": {"$ref": "#/$defs/itemRef"}
      }
    },
    "capabilityGap": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {"type": "string", "maxLength": 140},
        "evidence": {"type": "string"},
        "ref": {"$ref": "#/$defs/itemRef"}
      }
    },
    "marketSignalsSection": {
      "type": "object",
      "required": ["title", "benchmark_changes", "benchmark_watch", "pricing_changes", "adoption_signals", "capability_gaps", "empty_message"],
      "properties": {
        "title": {"type": "string"},
        "benchmark_changes": {"type": "array", "items": {"$ref": "#/$defs/benchmarkChange"}},
        "benchmark_watch": {"type": "array", "items": {"$ref": "#/$defs/benchmarkWatch"}},
        "pricing_changes": {"type": "array", "items": {"$ref": "#/$defs/pricingChange"}},
        "adoption_signals": {"type": "array", "items": {"$ref": "#/$defs/adoptionSignal"}},
        "capability_gaps": {"type": "array", "items": {"$ref": "#/$defs/capabilityGap"}},
        "empty_message": {"type": "string"}
      }
    },
    "patternObservation": {
      "type": "object",
      "required": ["theme", "supporting_item_refs", "interpretation_for_tech_lead"],
      "properties": {
        "theme": {"type": "string", "maxLength": 60},
        "supporting_item_refs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": {"$ref": "#/$defs/itemRef"}
        },
        "interpretation_for_tech_lead": {"type": "string", "minLength": 100, "maxLength": 220}
      }
    },
    "patternObservationsSection": {
      "type": "object",
      "required": ["title", "items", "empty_message"],
      "properties": {
        "title": {"type": "string"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/patternObservation"}, "maxItems": 3},
        "empty_message": {"type": "string"}
      }
    },
    "experiment": {
      "type": "object",
      "required": ["title", "hypothesis", "steps", "time_budget_hours", "expected_output", "required_skills", "audience"],
      "properties": {
        "title": {"type": "string", "maxLength": 50},
        "hypothesis": {"type": "string", "maxLength": 180},
        "steps": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {"type": "string", "maxLength": 120}
        },
        "time_budget_hours": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {"type": "integer", "minimum": 1, "maximum": 40},
            "max": {"type": "integer", "minimum": 1, "maximum": 40}
          }
        },
        "expected_output": {"type": "string", "maxLength": 140},
        "required_skills": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {"type": "string", "maxLength": 30}
        },
        "audience": {"enum": ["team_pilot", "personal_workflow"]},
        "related_item_refs": {
          "type": "array",
          "items": {"$ref": "#/$defs/itemRef"}
        }
      }
    },
    "experimentsSection": {
      "type": "object",
      "required": ["title", "items", "empty_message"],
      "properties": {
        "title": {"type": "string"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/experiment"}},
        "empty_message": {"type": "string"}
      }
    },
    "practiceDigestItem": {
      "type": "object",
      "required": ["title", "source_name", "source_url", "summary", "applicability", "applicability_note", "origin"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 60},
        "source_name": {"type": "string"},
        "source_url": {"type": "string"},
        "summary": {"type": "string", "minLength": 120, "maxLength": 600},
        "applicability": {"enum": ["adopt_now", "wait_mature", "reference_only"]},
        "applicability_note": {"type": "string", "minLength": 1, "maxLength": 120},
        "origin": {
          "type": "object",
          "required": ["date", "title"],
          "properties": {
            "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
            "title": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "actionItem": {
      "type": "object",
      "required": [
        "recommendation",
        "rationale",
        "recommendation_type",
        "effort_person_days",
        "time_horizon",
        "team_size_applicability",
        "priority"
      ],
      "properties": {
        "recommendation": {"type": "string", "maxLength": 120},
        "rationale": {"type": "string", "maxLength": 240},
        "recommendation_type": {"enum": ["patch", "experiment", "adopt", "migrate", "monitor", "hire"]},
        "effort_person_days": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {"type": "number", "minimum": 0.25, "maximum": 180},
            "max": {"type": "number", "minimum": 0.25, "maximum": 180}
          }
        },
        "time_horizon": {"enum": ["this_week", "this_month", "this_quarter"]},
        "team_size_applicability": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["small_lt_10", "medium_10_50", "large_gt_50"]}
        },
        "success_metric": {"type": "string", "maxLength": 160},
        "priority": {"enum": ["P0", "P1", "P2"]},
        "references": {"type": "array", "items": {"$ref": "#/$defs/reference"}}
      }
    },
    "reference": {
      "type": "object",
      "required": ["date", "headline", "url", "section", "editorial_tier"],
      "properties": {
        "date": {"type": "string"},
        "headline": {"type": "string"},
        "url": {"type": "string"},
        "section": {"enum": ["frontier_models", "coding_agents", "general_agents"]},
        "editorial_tier": {"enum": ["core", "watch"]},
        "release_stage": {"enum": ["announced", "preview", "beta", "ga", "rumor"]},
        "published_at_confidence": {"enum": ["exact", "approximate", "inferred"]},
        "authority_score": {"type": "integer", "minimum": 1, "maximum": 5},
        "evidence_quote": {"type": "string", "maxLength": 120},
        "via_broad_search": {"type": "boolean"}
      }
    }
  }
}
