{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIReportDeepDive",
  "type": "object",
  "required": ["version", "type", "date", "event_slug", "title", "generated_at", "sections", "references"],
  "properties": {
    "version": {"const": "1.0"},
    "type": {"const": "deep_dive"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "event_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "title": {"type": "string", "minLength": 4, "maxLength": 80},
    "generated_at": {"type": "string"},
    "sections": {
      "type": "object",
      "required": ["background", "what_shipped_detail", "benchmarks_pricing", "ecosystem_reaction", "role_implications", "quick_start", "open_questions"],
      "properties": {
        "background": {"type": "string", "minLength": 80, "maxLength": 800},
        "what_shipped_detail": {"type": "string", "minLength": 150, "maxLength": 1200},
        "benchmarks_pricing": {"type": "string", "minLength": 50, "maxLength": 800},
        "ecosystem_reaction": {"type": "string", "minLength": 50, "maxLength": 800},
        "role_implications": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["role", "implication"],
            "properties": {
              "role": {"type": "string", "minLength": 2, "maxLength": 40},
              "implication": {"type": "string", "minLength": 20, "maxLength": 240}
            }
          }
        },
        "quick_start": {"type": "string", "minLength": 50, "maxLength": 600},
        "open_questions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "url"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "url": {"type": "string", "pattern": "^https?://"}
        }
      }
    }
  }
}
