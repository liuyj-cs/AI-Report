{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIDailyCandidateLedger",
  "type": "object",
  "required": ["version", "type", "date", "generated_at", "items"],
  "properties": {
    "version": {"const": "1.0"},
    "type": {"const": "daily_candidate_ledger"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "generated_at": {"type": "string"},
    "items": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidateRecord"}
    }
  },
  "$defs": {
    "candidateRecord": {
      "type": "object",
      "required": [
        "candidate_id",
        "headline",
        "proposed_section",
        "published_at",
        "source_attempt_refs",
        "verification_state",
        "editorial_tier",
        "decision",
        "decision_reason",
        "novelty_vs_yesterday",
        "event_type",
        "date_basis",
        "evidence_path",
        "why_today",
        "action_eligibility"
      ],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "headline": {"type": "string", "minLength": 1},
        "proposed_section": {"enum": ["frontier_models", "coding_agents", "general_agents", "unverified"]},
        "published_at": {"type": "string", "minLength": 1},
        "source_attempt_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "verification_state": {"type": "string", "minLength": 1},
        "editorial_tier": {"enum": ["core", "watch", "unverified", "not_applicable"]},
        "decision": {
          "enum": [
            "selected_core",
            "selected_watch",
            "selected_unverified",
            "rejected_window",
            "rejected_duplicate",
            "rejected_weak_evidence",
            "rejected_not_ai"
          ]
        },
        "decision_reason": {"type": "string", "minLength": 1},
        "novelty_vs_yesterday": {"type": "string", "minLength": 1},
        "event_type": {"enum": ["model_release", "coding_release", "partnership", "pricing", "benchmark", "compliance", "community_signal", "enterprise_update", "adoption_signal", "research_update"]},
        "date_basis": {"enum": ["official_event_date", "release_metadata", "section_date", "article_published_at", "page_updated_at", "community_snapshot_time", "inferred_from_search"]},
        "evidence_path": {"enum": ["primary", "media_plus_official_one_hop", "media_only", "community_snapshot", "search_only"]},
        "why_today": {"type": "string", "minLength": 1},
        "action_eligibility": {"enum": ["none", "monitor", "experiment", "full_action"]},
        "tracking_ref": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"decision": {"enum": ["selected_core", "selected_watch"]}},
            "required": ["decision"]
          },
          "then": {
            "not": {
              "properties": {"date_basis": {"const": "page_updated_at"}},
              "required": ["date_basis"]
            }
          }
        }
      ]
    }
  }
}
