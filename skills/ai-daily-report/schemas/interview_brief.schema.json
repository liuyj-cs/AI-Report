{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIReportInterviewBrief",
  "type": "object",
  "required": ["version", "type", "date", "slug", "person", "org", "role", "interview_title", "outlet", "original_url", "published_at", "published_at_confidence", "first_seen_date", "mode", "chinese_transcript", "lede", "key_points", "role_implications", "references"],
  "properties": {
    "version": {"const": "1.0"},
    "type": {"const": "interview"},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "person": {"type": "string", "minLength": 1, "maxLength": 60},
    "org": {"type": "string", "minLength": 1, "maxLength": 60},
    "role": {"type": "string", "minLength": 1, "maxLength": 80},
    "interview_title": {"type": "string", "minLength": 1, "maxLength": 120},
    "outlet": {"type": "string", "minLength": 1, "maxLength": 80},
    "original_url": {"type": "string", "pattern": "^https?://"},
    "published_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "published_at_confidence": {"enum": ["exact", "approximate", "inferred"]},
    "first_seen_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "mode": {"enum": ["linked_zh_transcript", "self_translated_full", "deep_summary_fallback"]},
    "chinese_transcript": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": {"type": "boolean"},
        "url": {"type": "string", "pattern": "^https?://"},
        "outlet": {"type": "string", "maxLength": 80}
      }
    },
    "lede": {"type": "string", "minLength": 200, "maxLength": 700},
    "key_points": {"type": "array", "minItems": 2, "maxItems": 8, "items": {"type": "string", "minLength": 1, "maxLength": 200}},
    "notable_quotes": {"type": "array", "maxItems": 5, "items": {"type": "object", "required": ["quote_zh"], "properties": {"quote_zh": {"type": "string", "minLength": 1, "maxLength": 200}, "src": {"type": "string", "maxLength": 200}}}},
    "role_implications": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "object", "required": ["role", "implication"], "properties": {"role": {"type": "string", "minLength": 2, "maxLength": 40}, "implication": {"type": "string", "minLength": 10, "maxLength": 240}}}},
    "full_translation": {"type": "array", "items": {"type": "object", "required": ["heading", "body"], "properties": {"heading": {"type": "string", "maxLength": 120}, "body": {"type": "string", "minLength": 1}}}},
    "references": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["source", "url"], "properties": {"source": {"type": "string", "minLength": 1}, "url": {"type": "string", "pattern": "^https?://"}}}},
    "follow_ups": {"type": "array", "maxItems": 5, "items": {"type": "string", "maxLength": 120}}
  }
}
